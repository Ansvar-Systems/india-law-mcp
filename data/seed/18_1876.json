    {
      "provision_ref": "s41",
      "section": "41",
      "title": "Repealed.",
      "content": "41. ic95610Continuance of prior rules as to matters for which rules may be made under the Act].---- Rep. by the Repealing and Amending Act, 1891 (12 of 1891)."
    },
    {
      "provision_ref": "s42",
      "section": "42",
      "title": "Penalty for breach of rules.",
      "content": "Whoever breaks any rule made or continued under this Act, not being a rule made by the 1[High Court], shall, on conviction before a Magistrate; be punishable with fine which may extend to fifty rupees, or with imprisonment for a term which may extend to six months, or with both.\n\n[Footnote] 1. Subs. by the A.O. 1950 for \"Chief Court\"."
    },
    {
      "provision_ref": "s43",
      "section": "43",
      "title": ". Repealed.",
      "content": "[Power to invest taluqdars with civil jurisdiction].— Rep. by the Oudh Civil Courts Acts, 1879 (13 of 1879.)"
    },
    {
      "provision_ref": "s44",
      "section": "44",
      "title": "Honorary police-officers",
      "content": "The State Government may, from time to time, confer on any person whom it thinks fit any power which may be exercised by a police-officer under any Act for the time being in force, and withdraw any power so conferred."
    },
